# Kidashi ABM — .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Data outputs (large files; commit only metadata/samples)
data/synthetic/*.csv
results/
!data/synthetic/.gitkeep
!results/.gitkeep

# Figures generated at runtime
analysis/figures/
!analysis/figures/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db